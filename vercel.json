      "dest": "/robots.txt"
    },
    {
      "src": "/llms.txt",
      "dest": "/llms.txt"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(favicon\\.ico|site\\.webmanifest|og-default\\.png|vuestic-admin-logo\\.png|vuestic-admin-image\\.png|android-chrome-.*\\.png|apple-touch-icon\\.png|favicon-.*\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(seo-nav|geo-nav|aeo-nav|schema-generator|domain-namer|ai-checker|llms-txt|glossary|articles|tutorials|news|backlinks|faq|about|contact|privacy|terms)",
      "dest": "/$1/index.html"
    },
    {
      "src": "/(articles|tutorials|news)/([^/]+)",
      "dest": "/$1/$2/index.html"
    },
    {
      "src": "/(seo-nav|geo-nav|aeo-nav|ai-checker|domain-namer)/([^/]+)",
      "dest": "/$1/$2/index.html"
    },
    {
      "src": "/zh/(articles|tutorials|news)/([^/]+)",
      "dest": "/zh/$1/$2/index.html"
    },
    {
      "src": "/zh/(seo-nav|geo-nav|aeo-nav|ai-checker|domain-namer)/([^/]+)",
      "dest": "/zh/$1/$2/index.html"
    },
    {
      "src": "/zh/(seo-nav|geo-nav|aeo-nav|schema-generator|domain-namer|ai-checker|llms-txt|glossary|articles|tutorials|news|backlinks|faq|about|contact|privacy|terms)",
      "dest": "/zh/$1/index.html"
    },
    {
      "src": "/zh(/)?",
      "dest": "/zh/index.html"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}
