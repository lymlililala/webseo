# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/api
#
# 复制本文件为 .env.local 并填入真实值。.env.local 已被 .gitignore 屏蔽，不会提交。

# 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# 前端公开 key（可公开，注入到前端 bundle）
# 新版 publishable 公钥，形如 sb_publishable_xxx（legacy anon JWT 已被 Supabase 禁用）
# 与 Vercel 环境变量 VITE_SUPABASE_PUBLISHABLE_KEY 同名
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# 服务端密钥（仅本地/CI 脚本使用，切勿提交，切勿暴露给前端）
# 新版 Supabase API 密钥，形如 sb_secret_xxx
# 与 Vercel 环境变量 SUPABASE_SECRET_KEY 同名
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# ── AI 域名起名工具（api/namer.js、api/serper.js）服务端密钥 ──
# 切勿加 VITE_ 前缀、切勿提交、切勿暴露给前端。

# deepseek（AI 起名）。生产环境配到 Vercel 环境变量 DEEPSEEK_API_KEY（标记 Sensitive）。
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Serper（Google 撞名检测）。
# 生产环境推荐放 Vercel Edge Config（key=SERPER_KEY，频繁轮换免重新部署）；
# 本地开发用此环境变量即可（api/serper.js 读不到 Edge Config 时会回退到它）。
SERPER_KEY=your-serper-key

# 多个 Serper key 自动接力（某个配额用尽/失效就自动切下一个）：
# 用逗号分隔填 SERPER_KEYS；它优先于上面的单个 SERPER_KEY。
# （Edge Config 里给 SERPER_KEY 存逗号分隔串或数组，效果相同。）
# SERPER_KEYS=key1,key2,key3

