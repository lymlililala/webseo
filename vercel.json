{
  "buildCommand": "npm run build:ci",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/llms.txt",
      "dest": "/llms.txt"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(favicon\\.ico|site\\.webmanifest|og-default\\.png|vuestic-admin-logo\\.png|vuestic-admin-image\\.png|android-chrome-.*\\.png|apple-touch-icon\\.png|favicon-.*\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(seo-nav|geo-nav|aeo-nav|schema-generator|ai-checker|llms-txt|glossary|articles|tutorials|news|faq)",
      "dest": "/$1/index.html"
    },
    {
      "src": "/(articles|tutorials|news)/([^/]+)",
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "dest": "/seo-nav/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}
